{
  "name": "panda-pet",
  "version": "0.1.0",
  "description": "一只安静陪你写代码的熊猫桌宠 —— 感知 Claude Code 状态的展示层",
  "license": "MIT",
  "author": "Panda Pet",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hbw123/bamboo.git"
  },
  "homepage": "https://github.com/hbw123/bamboo#readme",
  "bugs": {
    "url": "https://github.com/hbw123/bamboo/issues"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.pandapet.app",
    "productName": "Panda Pet",
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "**/*",
      "!build/**",
      "!dist/**"
    ],
    "extraResources": [
      {
        "from": "../hooks",
        "to": "hooks"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "extendInfo": {
        "LSUIElement": 1
      }
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
